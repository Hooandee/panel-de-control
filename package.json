{
  "name": "panel-de-control",
  "version": "0.2.4",
  "description": "Panel de control definitivo para PCs portátiles: TDP, ventiladores y más.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test:fe": "vitest run"
  },
  "author": "Hooandee",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/webpack": "^5.28.5",
    "react-router": "^8.1.0",
    "rollup": "^4.53.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.7.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.3",
      "esbuild": "^0.25.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
